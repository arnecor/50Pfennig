# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Supabase (local Docker — from `npm run db:status`)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-publishable-key-here

# Service role key for the seed script (npm run db:seed) — from `npm run db:status` → Secret
SUPABASE_SERVICE_KEY=your-local-secret-key-here

# For production, replace with your Supabase cloud project values:
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-cloud-anon-key-here
