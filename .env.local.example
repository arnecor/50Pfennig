# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# For multi-environment setup:
#   .env.local       → local Docker Supabase (this file)
#   .env.development → cloud dev/staging Supabase project
#   .env.production  → production Supabase (CI secrets only — never local)

# Environment identifier — used by scripts to prevent accidental prod ops
VITE_APP_ENV=local

# Feature flag: show environment + Supabase URL badge on the login screen
# Set to "true" for local/dev, leave unset or "false" for production
VITE_SHOW_ENV_BADGE=true

# Supabase (local Docker — from `npm run db:status`)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-publishable-key-here

# Service role key for the seed script (npm run db:seed) — from `npm run db:status` → Secret
SUPABASE_SERVICE_KEY=your-local-secret-key-here
