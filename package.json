{
  "name": "sharli",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/types.gen.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "node --env-file=.env.development scripts/seed.js",
    "db:cleanup-dev": "node --env-file=.env.development scripts/cleanup-dev.js",
    "db:seed-test": "node --env-file=.env.development scripts/seed-test.js",
    "db:seed-val-users": "node --env-file=.env.development scripts/seed-val-users.js",
    "db:remove-val-users": "node --env-file=.env.development scripts/remove-val-users.js",
    "generate-icons": "capacitor-assets generate --android",
    "icon": "node scripts/generate-android-icons.mjs"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^6.2.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/core": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/share": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/query-persist-client-core": "^5.56.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-query-persist-client": "^5.56.0",
    "@tanstack/react-router": "^1.56.0",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "i18next": "^23.15.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.6.0",
    "idb-keyval": "^6.2.0",
    "lucide-react": "^0.564.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.1.0",
    "@faker-js/faker": "^10.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.18",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "postcss": "^8.4.0",
    "supabase": "^2.82.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
