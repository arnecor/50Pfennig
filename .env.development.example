# Copy this file to .env.development and fill in your cloud dev/staging Supabase values.
# .env.development is gitignored — never commit real credentials.
#
# Used by:
#   npm run build:dev      → Vite build targeting dev Supabase
#   npm run db:seed:dev    → Seed the cloud dev project

# Environment identifier — must stay "development" to allow seed/migration scripts
VITE_APP_ENV=development

# Feature flag: show environment + Supabase URL badge on the login screen
VITE_SHOW_ENV_BADGE=true

# Supabase (cloud dev project — from Supabase dashboard)
VITE_SUPABASE_URL=https://your-dev-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-dev-anon-key-here

# Service role key for seed scripts — from Supabase dashboard → Settings → API
SUPABASE_SERVICE_KEY=your-dev-service-key-here
